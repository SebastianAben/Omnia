{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@omnia/config": ["packages/config/src/index.ts"],
      "@omnia/config/*": ["packages/config/src/*"],
      "@omnia/shared-utils": ["packages/shared-utils/src/index.ts"],
      "@omnia/shared-utils/*": ["packages/shared-utils/src/*"],
      "@omnia/types": ["packages/types/src/index.ts"],
      "@omnia/types/*": ["packages/types/src/*"],
      "@omnia/ui": ["packages/ui/src/index.ts"],
      "@omnia/ui/*": ["packages/ui/src/*"]
    }
  }
}
