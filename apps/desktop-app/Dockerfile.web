FROM node:22-alpine AS deps

WORKDIR /app

RUN corepack enable && corepack prepare pnpm@10.17.0 --activate

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/backend-api/package.json apps/backend-api/package.json
COPY apps/desktop-app/package.json apps/desktop-app/package.json
COPY apps/ai-worker/package.json apps/ai-worker/package.json
COPY packages/config/package.json packages/config/package.json
COPY packages/shared-utils/package.json packages/shared-utils/package.json
COPY packages/types/package.json packages/types/package.json
COPY packages/ui/package.json packages/ui/package.json

RUN pnpm install --frozen-lockfile

FROM deps AS builder

ARG NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
ENV NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL

COPY . .

RUN pnpm --filter @omnia/desktop-app exec next build --no-lint

FROM nginx:1.27-alpine AS runner

COPY apps/desktop-app/nginx.web.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/apps/desktop-app/out /usr/share/nginx/html

EXPOSE 80
