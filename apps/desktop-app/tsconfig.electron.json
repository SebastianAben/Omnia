{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "electron",
    "outDir": "dist-electron",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "types": ["node"],
    "lib": ["ES2022", "DOM"],
    "noEmit": false,
    "verbatimModuleSyntax": false,
    "isolatedModules": false
  },
  "include": ["electron/**/*.ts"]
}
