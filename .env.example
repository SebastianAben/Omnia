# Root environment template
# Copy values into app-specific environment files as needed.
# Do not commit real production secrets.

# Shared
NODE_ENV=development
APP_ENV=local
LOG_LEVEL=info

# Frontend / Vercel / Electron Renderer
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_SYNC_STATUS_POLL_INTERVAL_MS=15000
NEXT_PUBLIC_SENTRY_DSN=

# Backend / Home Server
PORT=4000
HOST=0.0.0.0
PUBLIC_API_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://192.168.0.104:3000
DATABASE_URL=postgresql://omnia:omnia@localhost:55433/omnia
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-local-development-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace-with-local-refresh-secret
REFRESH_TOKEN_EXPIRES_IN=30d
SENTRY_DSN=

# AI Worker
AI_WORKER_CONCURRENCY=2
LLM_PROVIDER=gemini
LLM_API_KEY=
LLM_MODEL=gemini-2.5-flash
LLM_TIMEOUT_MS=20000
LLM_INSIGHT_TTL_MINUTES=15
LLM_MAX_INSIGHTS=8
LLM_MAX_CONTEXT_ROWS=30
LLM_GENERATION_COOLDOWN_MINUTES=60
