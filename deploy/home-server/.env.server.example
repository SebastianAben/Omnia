COMPOSE_PROJECT_NAME=omnia-dev
BACKEND_IMAGE=ghcr.io/sebastianaben/omnia-backend-api:dev
BACKEND_HOST_BIND=127.0.0.1
BACKEND_HOST_PORT=4101

APP_ENV=staging
PORT=4000
PUBLIC_API_URL=https://api-dev-omnia.albern.space
CORS_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql://omnia:replace-with-hex-password@postgres:5432/omnia
REDIS_URL=redis://redis:6379
JWT_SECRET=replace-with-long-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace-with-long-refresh-secret
LOG_LEVEL=info

POSTGRES_USER=omnia
POSTGRES_PASSWORD=replace-with-hex-password
POSTGRES_DB=omnia
